{
  "name": "local-event-discovery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "build:client": "esbuild src/assets/js/main.ts src/assets/js/contact.ts src/assets/js/content-workflow.ts --bundle --minify --target=esnext --outdir=src/assets/js --entry-names=[name]",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:a11y-gate": "vitest --run tests/a11y/axe.test.ts",
    "test:screen-reader-smoke": "node scripts/accessibility/screen-reader-smoke.mjs",
    "test:coverage": "vitest --run --coverage",
    "rollout:plan": "node scripts/rollout/feature-rollout-plan.mjs",
    "rollout:guard": "node scripts/rollout/rollback-guard.mjs",
    "rollout:execute": "node scripts/rollout/phase-execution.mjs",
    "rollout:promote": "node scripts/rollout/phase-promotion.mjs",
    "rollout:audit": "node scripts/rollout/phase-audit.mjs",
    "rollout:dwell": "node scripts/rollout/phase-dwell.mjs",
    "rollout:govern": "node scripts/rollout/phase-governor.mjs",
    "rollout:manifest": "node scripts/rollout/deployment-manifest.mjs",
    "rollout:rehearsal": "node scripts/rollout/rollback-rehearsal.mjs",
    "rollout:handoff": "node scripts/rollout/handoff-bundle.mjs",
    "rollout:consistency": "node scripts/rollout/cross-phase-consistency.mjs",
    "rollout:drill": "node scripts/rollout/rollback-drill-matrix.mjs",
    "rollout:closeout": "node scripts/rollout/program-closeout.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "agent:pr-quality": "node scripts/agents/pr-quality.mjs",
    "agent:feature-compliance": "node scripts/agents/feature-compliance.mjs",
    "agent:api-contract": "node scripts/agents/api-contract.mjs",
    "agent:analytics-integrity": "node scripts/agents/analytics-integrity.mjs",
    "agent:seo-content": "node scripts/agents/seo-content.mjs",
    "agent:data-quality": "node scripts/agents/data-quality.mjs",
    "agent:ui-regression": "node scripts/agents/ui-regression.mjs",
    "agent:ui-regression:baseline": "UPDATE_BASELINE=1 node scripts/agents/ui-regression.mjs",
    "agent:search-calibration": "node scripts/agents/search-calibration.mjs",
    "agent:neighborhood-fit-calibration": "node scripts/agents/neighborhood-fit-calibration.mjs",
    "agent:recommendation-uplift-eval": "node scripts/agents/recommendation-uplift-eval.mjs",
    "agent:weekly-kpi-query-clusters": "node scripts/agents/weekly-kpi-query-clusters.mjs",
    "agent:metrics-summary": "node scripts/agents/metrics-summary.mjs",
    "agent:release-telemetry-dashboard": "node scripts/agents/release-telemetry-dashboard.mjs",
    "agent:release-notes-summary": "node scripts/agents/release-notes-summary.mjs",
    "agent:release-gate": "node scripts/agents/release-gate.mjs",
    "agent:all": "node scripts/agents/run-all.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@ts-rest/core": "^3.52.0",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.11.0",
    "@types/jsdom": "^28.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "axe-core": "^4.9.0",
    "drizzle-kit": "^0.21.0",
    "esbuild": "^0.21.0",
    "fast-check": "^3.19.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.57.0"
  }
}
